# Copy this file to .env and fill in your values.
# Never commit .env to version control.

ANTHROPIC_API_KEY=your-key-here

# --- Attestation instrumentation (optional) ---
# Leave any of these unset and the instrumentation becomes a no-op.
# seo-agent will run identically with or without these.

# Path to clone of github.com/dannwaneri/production-safe-agent-loop
# (defaults to ~/production-safe-agent-loop if unset)
# PSAL_PATH=/path/to/production-safe-agent-loop

# Where to write fingerprint rows. Parent dir is auto-created.
# ATTESTATION_LEDGER_DB=~/.attestation/seo-agent.db

# Anthropic Admin API key — separate credential from ANTHROPIC_API_KEY.
# Required for run_verifier.py if using the live API path.
# Only available on Team / Enterprise orgs — individual orgs typically can't
# create one. If unset, set ATTESTATION_USAGE_CSV below instead (CSV mode).
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# Path to a CSV exported from Console > Analytics > Usage.
# Alternative to ANTHROPIC_ADMIN_API_KEY for individual orgs.
# Workflow: export weekly from Console UI, save here, run verifier.
# ATTESTATION_USAGE_CSV=~/.attestation/usage-export.csv

# How many days of history to diff in CSV mode (default 7).
# ATTESTATION_LOOKBACK_DAYS=7

# Identifiers — used to scope the Admin API usage query to this agent.
# Find these in the Anthropic Console under API keys / Workspaces.
# ANTHROPIC_API_KEY_ID=apikey_01...
# ANTHROPIC_WORKSPACE_ID=wrkspc_01...

# Set to any value to print instrumentation errors to stderr.
# Otherwise instrumentation failures are silent (the agent keeps running).
# ATTESTATION_DEBUG=1
